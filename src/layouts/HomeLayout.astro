---
interface Props {
  fullTitle: string;
  description: string;
}
const { fullTitle, description } = Astro.props;
import siteConfig from "@/config";
import "@/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content={siteConfig.colors.megaBlueDark}
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content={siteConfig.colors.megaBlue}
    />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://github.com/ggliv.png" />
    {
      description && (
        <>
          <meta property="og:description" content={description} />
          <meta name="description" content={description} />
        </>
      )
    }
  </head>

  <body
    class:list={[
      "min-h-screen",
      "bg-gray-900",
      "light:bg-gray-100",
      "text-gray-100",
      "light:text-gray-900",
      "font-sans",
      "flex",
      "flex-col",
      "gap-[2.5rem]",
      "items-center",
      "justify-center",
      "leading-[1.2]",
      "text-[1.25em]",
      "text-center",
    ]}
  >
    <div
      class:list={[
        "mb-auto",
        "bg-mega-blue",
        "light:bg-mega-blue-light",
        "h-[1rem]",
        "w-full",
      ]}></div>
    <slot />
    <div
      class:list={[
        "mt-auto",
        "bg-mega-blue",
        "light:bg-mega-blue-light",
        "h-[1rem]",
        "w-full",
      ]}></div>
  </body>
</html>
