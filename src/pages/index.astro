---
import HomeLayout from "@/layouts/HomeLayout.astro";
import { Picture } from "astro:assets";
import profileImage from "@/assets/images/profile.webp";
import siteConfig from "@/config";
---

<HomeLayout
  fullTitle={siteConfig.siteTitle}
  description={siteConfig.siteDescription}
>
  <div
    class:list={[
      "text-center",
      "text-[2.5rem]",
      "flex",
      "flex-col",
      "items-center",
      "gap-[1rem]",
    ]}
  >
    <Picture
      src={profileImage}
      alt="Profile shot of Gabe Livengood"
      class:list={[
        "w-[6.75em]",
        "max-w-full",
        "h-auto",
        "rounded-full",
        "border-4",
        "border-[gray]",
        "bg-white",
      ]}
    />
    <div>
      <script>
        let greetings = ["Hey", "Howdy", "Sup", "Hi", "Yo", "Hello", "Heya"];
        let h = new Date().getHours();
        if (5 <= h && h <= 11) {
          greetings.push("Morning");
        } else if (12 <= h && h <= 17) {
          greetings.push("Afternoon");
        } else if (18 <= h && h <= 23) {
          greetings.push("Evening");
        }
        window.addEventListener("DOMContentLoaded", () => {
          let greetingElement;
          if ((greetingElement = document?.getElementById("greeting"))) {
            greetingElement.innerText =
              greetings[Math.floor(Math.random() * greetings.length)];
          }
        });
      </script>
      <div><span id="greeting"><noscript>Hey</noscript></span>, I'm</div>
      <b>Gabe Livengood</b>
    </div>
    <div
      class:list={[
        "bg-mega-blue",
        "light:bg-mega-blue-light",
        "text-gray-100",
        "rounded-[0.5rem]",
        "px-[0.5rem]",
        "pb-[0.1rem]",
        "font-fredoka",
        "text-[0.9em]",
        "transform",
        "rotate-[-0.01turn]",
      ]}
      ><b>(@ggliv)</b>
    </div>
  </div>
  <div class="text-center">
    <p class="max-w-[90%] md:max-w-[75%] mx-auto mb-[1.5rem]">
      I'm a hacker at heart interested in computing, mathematics, music, and the
      wider world around us.
    </p>
    <ul class="inline-flex flex-wrap gap-3 link">
      <li>
        <a href="/blog/">Blog</a>
      </li>
      <li>
        <Fragment
          set:html={`<a href="&#109;&#097;&#105;&#108;&#116;&#111;:&#103;&#097;&#098;&#101;&#064;&#103;&#103;&#108;&#105;&#118;&#046;&#099;&#111;&#109;">Email</a>`}
        />
      </li>
      <li>
        <a href="//github.com/ggliv">GitHub</a>
      </li>
      <li>
        <a href="//www.linkedin.com/in/gabe-livengood/">LinkedIn</a>
      </li>
      <li>
        <a href="/roll">Roll</a>
      </li>
    </ul>
  </div>
</HomeLayout>
